[Unit]
Description=winmiddle — Windows-faithful middle-click autoscroll
Documentation=https://github.com/eslachance/winscroll
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/winmiddle -v
Restart=on-failure
RestartSec=2
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=graphical-session.target
